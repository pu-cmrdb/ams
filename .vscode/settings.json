{
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  },
  "eslint.format.enable": true,
  "editor.formatOnSave": true,
  "editor.rulers": [
    120
  ],
  "editor.indentSize": 2,
  "files.eol": "\n",
  "files.autoSave": "onFocusChange",
  "typescript.tsdk": "node_modules/typescript/lib",
  "peacock.color": "slategray",
}